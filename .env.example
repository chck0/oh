# =============================================================
# .env.example — 환경변수 템플릿
#   1) 이 파일을 `.env`로 복사
#   2) 각 키 발급받아 값 채움
#   3) .env는 git에 절대 올리지 않음 (.gitignore 처리됨)
#
# Vercel 배포 시에는 이 키들을 'Project Settings → Environment Variables'에
# 같은 이름으로 등록 (Production / Preview / Development 모두 체크 권장)
# =============================================================

# ── [Vercel 런타임 필수] Supabase Postgres ────────────────────
# 'Settings → Database → Connection string' 에서 복사
#   - Vercel 함수: pgBouncer 6543 포트 (Transaction mode) 권장
#     postgresql://postgres.[REF]:[PWD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#   - 로컬 이관 스크립트: 5432 Direct (대량 INSERT용)
#     postgresql://postgres:[PWD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=

# ── [Vercel 런타임 필수] 카카오 (주소 검색) ────────────────────
# developers.kakao.com
KAKAO_REST_API_KEY=
KAKAO_JS_KEY=

# ── [Vercel 런타임 필수] ODsay (대중교통 길찾기) ──────────────
# lab.odsay.com — KEY_1 부터 N개 등록. 키 N개일수록 동시 호출 한도 ↑
ODSAY_KEY_1=
ODSAY_REFERER_1=
ODSAY_KEY_2=
ODSAY_REFERER_2=

# ── [Vercel 런타임 필수] Anthropic Claude (친구 한 마디) ──────
# console.anthropic.com
ANTHROPIC_API_KEY=

# ── [로컬 scripts 전용 — Vercel에선 불필요] ──────────────────
# 데이터 파이프라인(scripts/)에서만 사용. Vercel 등록 X.
VWORLD_API_KEY=
MOLIT_API_KEY=
KAKAO_NATIVE_KEY=
# NEIS 교육정보 개방 포털 (초등학교 정보) — open.neis.go.kr
NEIS_API_KEY=

# ── [로컬 dev 전용] SQLite DB 경로 ───────────────────────────
# DATABASE_URL 이 설정되면 무시됨
DB_PATH=data/apartment.db
