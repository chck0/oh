{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/worklog_backup.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/db_logger.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/worklog_backup.py"
          }
        ]
      }
    ]
  }
}
