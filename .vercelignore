# Vercel 함수 번들에서 제외할 것들
# (250MB 함수 사이즈 한도 + 보안)

# ── 로컬 데이터 / DB / 로그 ──────────────────────────────────
data/
logs/
*.db
*.db-journal
*.db-wal
*.db-shm

# ── ngrok 바이너리 (32MB) ───────────────────────────────────
ngrok.exe

# ── 실험용 코드 ──────────────────────────────────────────────
sandbox/

# ── 데이터 파이프라인 (런타임 미사용) ─────────────────────────
scripts/

# ── 배포 설정 (EC2용) ────────────────────────────────────────
deploy/

# ── 비밀키 ───────────────────────────────────────────────────
.env
.env.local

# ── 캐시 / 빌드 ──────────────────────────────────────────────
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── 에디터 ───────────────────────────────────────────────────
.vscode/
.idea/
.claude/
