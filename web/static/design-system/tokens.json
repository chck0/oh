{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Baduki Design System Tokens v0.2 — Map Overlay Edition",
  "color": {
    "$description": "Color tokens. Use semantic tokens in product code, not primitive scales directly.",
    "primitive": {
      "$description": "Raw color scales. Do not use directly in components.",
      "red": {
        "50":  { "$value": "#FDF4F2", "$type": "color" },
        "100": { "$value": "#F9DDD6", "$type": "color" },
        "200": { "$value": "#F2BAA9", "$type": "color" },
        "300": { "$value": "#E89789", "$type": "color" },
        "400": { "$value": "#DA6E58", "$type": "color" },
        "500": { "$value": "#C8462F", "$type": "color" },
        "600": { "$value": "#A82E1B", "$type": "color", "$description": "MAIN. Use for primary CTAs and brand red." },
        "700": { "$value": "#8E2618", "$type": "color" },
        "800": { "$value": "#7E2113", "$type": "color", "$description": "Hover state for red-600." },
        "900": { "$value": "#4D140C", "$type": "color", "$description": "Active/pressed state." }
      },
      "gray": {
        "$description": "Warm gray scale. 2% yellow-brown tint to harmonize with map tiles.",
        "white": { "$value": "#FFFFFF", "$type": "color" },
        "50":  { "$value": "#FAF9F7", "$type": "color" },
        "100": { "$value": "#F1EFEB", "$type": "color" },
        "200": { "$value": "#E8E6E3", "$type": "color" },
        "300": { "$value": "#C9C5BF", "$type": "color" },
        "400": { "$value": "#A6A19A", "$type": "color" },
        "500": { "$value": "#8A857E", "$type": "color" },
        "600": { "$value": "#6B6661", "$type": "color" },
        "700": { "$value": "#4A4642", "$type": "color" },
        "800": { "$value": "#2E2B28", "$type": "color" },
        "900": { "$value": "#1A1816", "$type": "color" }
      },
      "green": {
        "100": { "$value": "#E6F0E5", "$type": "color" },
        "700": { "$value": "#2D6A3F", "$type": "color" }
      },
      "amber": {
        "100": { "$value": "#FBF1DC", "$type": "color" },
        "700": { "$value": "#8C5E0E", "$type": "color" }
      },
      "blue": {
        "100": { "$value": "#E4ECF4", "$type": "color" },
        "700": { "$value": "#2E4E6E", "$type": "color" }
      }
    },
    "semantic": {
      "$description": "Use these in components. They reference primitives and carry meaning.",
      "brand": {
        "primary":   { "$value": "{color.primitive.red.600}", "$type": "color" },
        "hover":     { "$value": "{color.primitive.red.800}", "$type": "color" },
        "active":    { "$value": "{color.primitive.red.900}", "$type": "color" },
        "disabled":  { "$value": "{color.primitive.red.300}", "$type": "color" },
        "bg-subtle": { "$value": "{color.primitive.red.50}",  "$type": "color" }
      },
      "background": {
        "panel":     { "$value": "{color.primitive.gray.white}", "$type": "color", "$description": "Default panel background. Always white." },
        "subtle":    { "$value": "{color.primitive.gray.50}",    "$type": "color", "$description": "Hover states, section dividers." },
        "muted":     { "$value": "{color.primitive.gray.100}",   "$type": "color", "$description": "Inactive cards, secondary panels." }
      },
      "border": {
        "default":   { "$value": "{color.primitive.gray.200}",   "$type": "color" },
        "strong":    { "$value": "{color.primitive.gray.300}",   "$type": "color" },
        "focus":     { "$value": "{color.primitive.red.600}",    "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{color.primitive.gray.900}",   "$type": "color" },
        "secondary": { "$value": "{color.primitive.gray.700}",   "$type": "color" },
        "tertiary":  { "$value": "{color.primitive.gray.500}",   "$type": "color" },
        "disabled":  { "$value": "{color.primitive.gray.400}",   "$type": "color" },
        "on-brand":  { "$value": "{color.primitive.gray.white}", "$type": "color", "$description": "Text on red backgrounds." }
      },
      "status": {
        "success-bg":   { "$value": "{color.primitive.green.100}", "$type": "color" },
        "success-text": { "$value": "{color.primitive.green.700}", "$type": "color" },
        "warning-bg":   { "$value": "{color.primitive.amber.100}", "$type": "color" },
        "warning-text": { "$value": "{color.primitive.amber.700}", "$type": "color" },
        "info-bg":      { "$value": "{color.primitive.blue.100}",  "$type": "color" },
        "info-text":    { "$value": "{color.primitive.blue.700}",  "$type": "color" }
      },
      "map-pin": {
        "$description": "Map pin colors. See DESIGN_SYSTEM.md section 4 for usage rules.",
        "recommended-bg":   { "$value": "{color.primitive.red.600}",   "$type": "color" },
        "recommended-text": { "$value": "{color.primitive.gray.white}","$type": "color" },
        "default-bg":       { "$value": "{color.primitive.gray.white}","$type": "color" },
        "default-text":     { "$value": "{color.primitive.gray.900}",  "$type": "color" },
        "default-border":   { "$value": "{color.primitive.gray.300}",  "$type": "color" },
        "visited-bg":       { "$value": "{color.primitive.gray.100}",  "$type": "color" },
        "visited-text":     { "$value": "{color.primitive.gray.500}",  "$type": "color" },
        "selected-bg":      { "$value": "{color.primitive.gray.900}",  "$type": "color" },
        "selected-text":    { "$value": "{color.primitive.gray.white}","$type": "color" },
        "cluster-bg":       { "$value": "{color.primitive.gray.white}","$type": "color" },
        "cluster-text":     { "$value": "{color.primitive.red.600}",   "$type": "color" },
        "cluster-border":   { "$value": "{color.primitive.red.600}",   "$type": "color" }
      }
    }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px rgba(0, 0, 0, 0.06)",  "$type": "shadow", "$description": "Tooltips, small badges" },
    "md": { "$value": "0 2px 8px rgba(0, 0, 0, 0.08)",  "$type": "shadow", "$description": "Default pins, cards" },
    "lg": { "$value": "0 4px 16px rgba(0, 0, 0, 0.10)", "$type": "shadow", "$description": "Side panels, filter sheets" },
    "xl": { "$value": "0 8px 28px rgba(0, 0, 0, 0.14)", "$type": "shadow", "$description": "Modals, hover-elevated cards" },
    "pin-recommended": { "$value": "0 3px 10px rgba(168, 46, 27, 0.40)", "$type": "shadow", "$description": "Red glow under recommended map pins only" }
  },
  "radius": {
    "sm":   { "$value": "4px",  "$type": "dimension", "$description": "Inputs, small chips" },
    "md":   { "$value": "8px",  "$type": "dimension", "$description": "Buttons, cards" },
    "lg":   { "$value": "12px", "$type": "dimension", "$description": "Panels, large cards" },
    "pill": { "$value": "9999px","$type": "dimension","$description": "Tags, search bars, filter chips" }
  },
  "spacing": {
    "0":  { "$value": "0px",   "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "20px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" }
  }
}
