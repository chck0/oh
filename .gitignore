# ── 에디터 / 도구 ─────────────────────────────────────────────
.codex/

# ── 환경변수 / 비밀키 ─────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── 데이터 / DB / 로그 ────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
data/backup/
data/raw/
logs/
*.log

# ── 에디터 / IDE 로컬 설정 ───────────────────────────────────
# .claude/ 안의 개인 설정·세션 상태는 무시하되, 팀 공유용 훅·설정은 git에 올림
.claude/*
!.claude/settings.json
!.claude/hooks/

# ── 작업 일지(worklog) ───────────────────────────────────────
# 깔끔하게 정리된 docs/worklog/<이름>.md 는 공유(추적)하고,
# 개인용 raw 백업과 작성자 이름 파일은 로컬에만 둔다.
docs/worklog/.raw/
docs/worklog/.author

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── 에디터 ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── 빌드 / 배포 ───────────────────────────────────────────────
dist/
build/
*.egg

# ── sandbox/ — 작업용 임시 코드 (README만 트래킹) ─────────────
sandbox/*
!sandbox/README.md
!sandbox/.gitkeep

# ── 로딩 영상 — 저작권 회색지대지만 데모용으로 포함 (57MB) ──
# (필요시 다시 web/static/videos/ 로 ignore 처리)

# ── 로컬 도구 / 바이너리 ─────────────────────────────────────
ngrok.exe
*.exe

# ── Vercel 빌드 산출물 ───────────────────────────────────────
.vercel/

# pytest / coverage
htmlcov/
.coverage
.coverage.*

# ── OMC 로컬 상태 (세션/PRD/진행상황 — 로컬 전용) ──────────────
.omc/
.gstack/
